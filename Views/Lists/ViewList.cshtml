@model Inventory_Tracker.Models.ItemList

<h1 class="text-center"><strong>@Model.Name</strong></h1>

<a href="/Inventory/Add?listName=@MUri.EscapeDataString(Model.Name)" class="btn btn-success mb-3">Add Item</a>

<table class="table table-striped table=bordered">
	<tr>
		<th>Name</th>
		<th>Quantity</th>
		<th>Price</th>
		<th>Total</th>
		<th>Actions</th>
	</tr>

	@for (int i=0; i< Model.Items.Count; i++)
	{
		<tr>
		<td>@Model.Items[i].Name</td>
		<td>@Model.Items[i].Quantity</td>
		<td>@Model.Items[i].Price</td>
		<td>$@(Model.Items[i].Price * Model.Items[i].Quantity)</td>
		<td>
			<a href="/Lists/EditItem?index=@i&name=@Model.Name" class= "btn btn-warning btn-sm">Edit</a>
			<a href="/Lists/DeleteItem?index=@i&name=@Model.Name" class= "btn btn-danger btn-sm">Delete</a>
		</td>
		</tr>
	}
</table>

@{
	decimal listTotal = Model.Items.Sum(i => i.Price * i.Quantity);
}
<h3>Overall Price: $@listTotal</h3>
