@model Inventory_Tracker.Models.Item

<h1 class="text-center"><strong>@ViewBag.ListName</strong></h1>

<form method="post" action="/Inventory/Add">

    <!-- Keep the list name coming back on POST -->
    <input type="hidden" name="listName" value="@ViewBag.ListName" />

    <div class="form-group">
        <label>Item Name</label>
        <input type="text" name="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>Quantity</label>
        <input type="number" name="Quantity" class="form-control" />
    </div>

    <div class="form-group">
        <label>Price</label>
        <input type="number" step="0.01" name="Price" class="form-control" />
    </div>

    @if (ViewBag.ListId != null)
    {
        <!-- This is the critical hidden field -->
        <input type="hidden" name="itemListId" value="@ViewBag.ListId" />

        <div class="alert alert-info">
            Adding item to list: <strong>@ViewBag.ListName</strong>
        </div>
    }
    else
    {
        <div class="form-group">
            <label>Select List</label>
            @Html.DropDownListFor(
                m => m.ItemListId,
                new SelectList(ViewBag.Lists, "Id", "Name"),
                "Select a List",
                new { @class = "form-control" }
            )
        </div>
    }

    <button type="submit" class="btn btn-primary">Save</button>
</form>

<a class="fab" href="/Lists/Create">+</a>

